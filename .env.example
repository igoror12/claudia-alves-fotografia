# ─── Base de dados (Vercel Postgres ou Neon) ───────────────────
DATABASE_URL="postgresql://user:password@host:5432/claudia_fotografia?sslmode=require"
# Connection pooling (Vercel Postgres dá ambas)
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# ─── Vercel Blob Storage ────────────────────────────────────────
# Gerar em: vercel.com → Storage → Create Blob Store → Connect
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# ─── NextAuth ───────────────────────────────────────────────────
# Gerar com: openssl rand -base64 32
NEXTAUTH_SECRET="cole-aqui-uma-string-aleatoria-de-32+ chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── Conta admin (seed inicial) ─────────────────────────────────
ADMIN_EMAIL="claudia@claudiaalves.pt"
ADMIN_PASSWORD="trocar-em-producao"

# ─── Anthropic Claude API ───────────────────────────────────────
# Gerar em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxx"
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ─── Email (opcional, para notificar contactos) ─────────────────
RESEND_API_KEY=""
NOTIFY_EMAIL="claudia@claudiaalves.pt"
